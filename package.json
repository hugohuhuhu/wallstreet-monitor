{
  "name": "wallstreet-monitor",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x.x"
  },
  "scripts": {
    "start": "node src/server.js",
    "run": "node src/cli.js run --config config/sources.sample.json",
    "watch": "node src/cli.js watch --config config/sources.sample.json --interval 300",
    "events": "node src/cli.js events --limit 20",
    "review": "node src/cli.js review --status pending",
    "dashboard": "node src/server.js --config config/sources.sample.json --port 4310",
    "test": "node --test --test-isolation=none"
  }
}
